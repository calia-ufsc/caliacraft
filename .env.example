# Directory for persistent data (survives restarts)
# On JupyterHub: ~/privado — on a regular machine: ~ or any path you prefer
DATA_DIR=$HOME/data

# Directory for user binaries (no sudo needed)
BIN_DIR=$HOME/bin

# NeoForge version (MC 1.21.1)
NEOFORGE_VERSION=21.1.228

# CurseForge server pack download URL (optional — leave empty for vanilla NeoForge)
SERVER_PACK_URL=

# RAM to allocate to the Minecraft server
MC_RAM_MIN=2G
MC_RAM_MAX=8G

# Tunnel mode: "playit" or "frp"
TUNNEL_MODE=playit

# frp tunnel (only needed if TUNNEL_MODE=frp)
FRP_SERVER_ADDR=
FRP_TOKEN=
