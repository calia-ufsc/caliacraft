# ── Directories ───────────────────────────────────────────────────────────────
# On JupyterHub: ~/privado — on a regular machine: ~ or any path
DATA_DIR=$HOME/data
BIN_DIR=$HOME/bin

# ── Java ──────────────────────────────────────────────────────────────────────
JAVA_URL=https://cdn.azul.com/zulu/bin/zulu21.42.19-ca-jdk21.0.7-linux_x64.tar.gz

# ── Tool versions ─────────────────────────────────────────────────────────────
JUST_VERSION=1.56.0
PLAYIT_VERSION=0.15.26
FRP_VERSION=0.70.0

# ── Minecraft ─────────────────────────────────────────────────────────────────
NEOFORGE_VERSION=21.1.233

# Server pack zip from CurseForge — "Additional Files" tab on the modpack page.
# Leave empty for vanilla NeoForge (no mods).
SERVER_PACK_URL=

# RAM allocated to the Minecraft server
MC_RAM_MIN=4G
MC_RAM_MAX=12G

# ── Tunnel ────────────────────────────────────────────────────────────────────
TUNNEL_MODE=frp

# frp (only needed if TUNNEL_MODE=frp)
FRP_SERVER_ADDR=
FRP_TOKEN=
